# Never expose these in frontend code.
# Set these inside Vercel/Render/Railway environment variables.

# Optional gateway/provider keys
ARENA_API_KEY=replace_me
OPENAI_API_KEY=replace_me
ANTHROPIC_API_KEY=replace_me
GOOGLE_API_KEY=replace_me
RUNWAY_API_KEY=replace_me
KLING_API_KEY=replace_me
REPLICATE_API_TOKEN=replace_me
FAL_KEY=replace_me

# Simple demo admin secret. Replace with real auth before production.
ADMIN_SECRET=change_this_secret

# App config
NEXT_PUBLIC_APP_NAME=IMPROX AI

# Simple private team access code for fast launch
TEAM_ACCESS_CODE=IMPROX-TEAM-2026

# Fast real chat connector: OpenAI-compatible endpoint
IMPROX_GENIUS_API_KEY=replace_me
IMPROX_GENIUS_API_URL=https://api.openai.com/v1/chat/completions
IMPROX_GENIUS_MODEL=gpt-4.1

# Private team usernames: username:password:role:display name separated by commas
TEAM_USERS=admin:ChangeMe123:admin:IMPROX Admin,editor:Editor123:enterprise:Production Editor,designer:Design123:creator:Designer

# NVIDIA API / NIM connectors
NVIDIA_API_KEY=replace_me
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_CHAT_MODEL=meta/llama-3.1-405b-instruct
IMPROX_IMAGE_API_URL=https://integrate.api.nvidia.com/v1/images/generations
IMPROX_IMAGE_EDIT_API_URL=https://integrate.api.nvidia.com/v1/images/edits
IMPROX_IMAGE_MODEL=black-forest-labs/flux_1-kontext-dev
IMPROX_IMAGE_EDIT_MODEL=qwen/qwen-image-edit-2511

# Optional magic access links: token:username:role:display name
TEAM_MAGIC_LINKS=editorlink2026:editor:enterprise:Production Editor,designlink2026:designer:creator:Designer

# Optional Gemini connector for IMPROX Genius Pro
# Set IMPROX_GENIUS_PROVIDER=gemini to use this
IMPROX_GENIUS_PROVIDER=openai-compatible
GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-2.5-pro
